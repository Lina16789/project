def reading(s):
    tokens = []
    b = ""

    for symbol in s:
        if symbol.isalnum() or symbol == '.':
            b += symbol
        else:
            if b:
                tokens.append(b)
                b = ""
            if symbol.strip() and symbol != ',':
                tokens.append(symbol)

    if b:
        tokens.append(b)

    return (tokens)
