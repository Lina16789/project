def reading(s):
    tokens = []
    b = ""

    for symbol in s:
        if symbol.isalnum() or symbol == '.':
            b += symbol
        else:
            if len(b)!=0:
                tokens.append(b)
                b = ""
            if len(symbol.strip())!=0 and symbol != ',':
                tokens.append(symbol)

    if b:
        tokens.append(b)

    return (tokens)
